# Secrets — never commit
.env

# Keys and certs. The repo is public: a private key committed here is
# compromised the moment it is pushed, and bots scrape new commits within
# minutes. Belt and braces, since these should never be in the tree at all.
*.pem
*.key
*.p12
credentials

# Claude Code local settings — per-machine, never commit
.claude/settings.local.json

# Data — local parquet store at repo root, never commit
# (anchored so src/diyquant/data/ stays tracked)
/data/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Notebooks: strip outputs before committing
notebooks/*.ipynb_checkpoints/

# Generated knowledge graph — regenerable, never commit
/graphify-out/

# OS
.DS_Store
Thumbs.db
